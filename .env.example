DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
DATABASE_URL=postgresql://bookforbook:bookforbook@localhost:5432/bookforbook
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Email — Proton Mail SMTP submission (https://proton.me/support/smtp-submission)
# EMAIL_HOST_USER is your Proton Mail address (e.g. you@bookforbook.com)
# EMAIL_HOST_PASSWORD is the SMTP token generated in Proton Mail settings (not your login password)
EMAIL_HOST=smtp.protonmail.ch
EMAIL_PORT=587
EMAIL_HOST_USER=your-proton-address@bookforbook.com
EMAIL_HOST_PASSWORD=your-proton-smtp-token
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@bookforbook.com

FRONTEND_URL=http://localhost:5173

# AWS S3 (optional — only needed for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
