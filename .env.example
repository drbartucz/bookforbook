DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
DATABASE_URL=postgresql://bookforbook:bookforbook@localhost:5432/bookforbook
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Email — Resend (https://resend.com) — used in production only
# In development, emails print to the console (see development.py)
# RESEND_API_KEY is generated in the Resend dashboard after adding your domain
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=noreply@bookforbook.com

FRONTEND_URL=http://localhost:5173

# AWS S3 (optional — only needed for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
