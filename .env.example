DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
DATABASE_URL=postgresql://bookforbook:bookforbook@localhost:5432/bookforbook
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Email — Resend (https://resend.com) — used in production only
# In development, emails print to the console (see development.py)
# RESEND_API_KEY is generated in the Resend dashboard after adding your domain
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=Book for Book <noreply@bookforbook.com>

FRONTEND_URL=http://localhost:5173

# Admin alert recipient for account lifecycle events
ADMIN_ACCOUNT_ALERT_EMAIL=john@bookforbook.com
ADMIN_ACCOUNT_ALERTS_ENABLED=True
# Skip alerts for likely test accounts (example domains / test-prefixed usernames)
ADMIN_ACCOUNT_ALERTS_SKIP_TEST_USERS=True
ADMIN_ACCOUNT_ALERT_TEST_DOMAINS=example.com,test.local,example.org
ADMIN_ACCOUNT_ALERT_TEST_PREFIXES=test,pytest,qa

# Match eligibility gate (hours). Set to 0 to disable account-age delay.
# Raise this (for example, 24 or 48) if bot abuse becomes a problem.
MATCH_ELIGIBILITY_MIN_ACCOUNT_AGE_HOURS=0

# AWS S3 (optional — only needed for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Backblaze B2 (database backups — used in production only)
# See docs/backups.md for setup instructions
# In development, backups land in <project_root>/backups/ (local filesystem)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# USPS Developer API (OAuth2 + Addresses v3)
# Client ID = Consumer Key, Client Secret = Consumer Secret from USPS developer portal.
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
# Optional: request narrower scope than app default (usually leave blank).
USPS_OAUTH_SCOPE=
# Production defaults. For TEM testing use:
# USPS_OAUTH_BASE_URL=https://apis-tem.usps.com/oauth2/v3
# USPS_ADDRESSES_BASE_URL=https://apis-tem.usps.com/addresses/v3
USPS_OAUTH_BASE_URL=https://apis.usps.com/oauth2/v3
USPS_ADDRESSES_BASE_URL=https://apis.usps.com/addresses/v3
USPS_API_TIMEOUT=8
