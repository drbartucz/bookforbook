CREATE TABLE IF NOT EXISTS "accounts_user" ("password" varchar(128) NOT NULL, "last_login" datetime NULL, "is_superuser" bool NOT NULL, "id" char(32) NOT NULL PRIMARY KEY, "email" varchar(254) NOT NULL UNIQUE, "email_verified" bool NOT NULL, "email_verified_at" datetime NULL, "username" varchar(150) NOT NULL UNIQUE, "account_type" varchar(20) NOT NULL, "is_verified" bool NOT NULL, "institution_name" varchar(255) NULL, "institution_url" varchar(200) NULL, "full_name" text NOT NULL, "address_line_1" text NOT NULL, "address_line_2" text NULL, "city" varchar(100) NOT NULL, "state" varchar(2) NOT NULL, "zip_code" varchar(10) NOT NULL, "total_trades" integer unsigned NOT NULL CHECK ("total_trades" >= 0), "avg_recent_rating" decimal NULL, "rating_count" integer unsigned NOT NULL CHECK ("rating_count" >= 0), "inactivity_warned_1m" datetime NULL, "inactivity_warned_2m" datetime NULL, "books_delisted_at" datetime NULL, "created_at" datetime NOT NULL, "updated_at" datetime NOT NULL, "last_active_at" datetime NOT NULL, "is_staff" bool NOT NULL, "is_active" bool NOT NULL, "address_verification_status" varchar(20) NOT NULL, "address_verified_at" datetime NULL, "deletion_completed_at" datetime NULL, "deletion_requested_at" datetime NULL, "deletion_scheduled_for" datetime NULL);
